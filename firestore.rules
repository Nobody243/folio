rules_version = '2';

// Each user can read and write only their own profile document under /users/{uid}.
// The document is keyed by Firebase Auth UID, so request.auth.uid === userId
// is the only check we need. No other collections are exposed.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
